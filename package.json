{
  "name": "record-new",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:web": "vite",
    "build:web": "vue-tsc --build && vite build",
    "dev:server": "npm run dev -w @record/server",
    "dev:miniapp": "npm run dev:mp-weixin -w @record/miniapp",
    "build:server": "npm run build -w @record/shared && npm run build -w @record/server",
    "build:miniapp": "npm run build:mp-weixin -w @record/miniapp",
    "postinstall": "node scripts/patch-uni-cli-shared.js",
    "db:generate": "npm run db:generate -w @record/server",
    "db:push": "npm run db:push -w @record/server",
    "deploy": "docker compose up -d --build"
  },
  "dependencies": {
    "echarts": "^5.6.0",
    "element-plus": "^2.9.7",
    "pinia": "^3.0.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.1",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/tsconfig": "^0.7.0",
    "typescript": "~5.8.3",
    "unplugin-auto-import": "^19.1.2",
    "unplugin-vue-components": "^28.4.1",
    "vite": "^6.2.3",
    "vite-plugin-vue-devtools": "^7.7.2",
    "vue-tsc": "^2.2.8"
  }
}
