{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u--(.*)": "uview-plus/components/u-$1/u-$1.vue",
      "^up-(.*)": "uview-plus/components/u-$1/u-$1.vue",
      "^u-([^-].*)": "uview-plus/components/u-$1/u-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/diet/index",
      "style": { "navigationBarTitleText": "饮食记录" }
    },
    {
      "path": "pages/weight/index",
      "style": { "navigationBarTitleText": "体重记录" }
    },
    {
      "path": "pages/workout/index",
      "style": { "navigationBarTitleText": "健身记录" }
    },
    {
      "path": "pages/carb-cycle/index",
      "style": { "navigationBarTitleText": "碳循环" }
    }
  ],
  "tabBar": {
    "color": "#909399",
    "selectedColor": "#3c9cff",
    "backgroundColor": "#ffffff",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/diet/index",
        "text": "饮食",
        "iconPath": "static/tab-diet.png",
        "selectedIconPath": "static/tab-diet-active.png"
      },
      {
        "pagePath": "pages/weight/index",
        "text": "体重",
        "iconPath": "static/tab-weight.png",
        "selectedIconPath": "static/tab-weight-active.png"
      },
      {
        "pagePath": "pages/workout/index",
        "text": "健身",
        "iconPath": "static/tab-workout.png",
        "selectedIconPath": "static/tab-workout-active.png"
      }
    ]
  },
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "健康记录",
    "navigationBarBackgroundColor": "#ffffff",
    "backgroundColor": "#f0f2f5"
  }
}
